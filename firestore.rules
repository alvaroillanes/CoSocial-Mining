rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && 
        incoming().keys().hasAll(['email', 'updatedAt']) &&
        incoming().email is string &&
        incoming().updatedAt == request.time;
    }

    // Due Diligence
    match /dueDocs/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
        isValidId(userId) &&
        incoming().keys().hasAll(['userId', 'rut', 'updatedAt', 'status']) &&
        incoming().userId == userId &&
        incoming().rut is string && incoming().rut.size() <= 20 &&
        incoming().status == 'pending' &&
        incoming().updatedAt == request.time;
      
      allow update: if isOwner(userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['rut', 'address', 'occupation', 'sourceOfFunds', 'updatedAt']) &&
        incoming().updatedAt == request.time;
    }

    // Leads (Public creation)
    match /leads/{leadId} {
      allow create: if isValidId(leadId) &&
        incoming().keys().hasAll(['email', 'createdAt']) &&
        incoming().email is string &&
        incoming().createdAt == request.time;
      
      allow read: if false; // Only admin via console or special logic
    }
  }
}
